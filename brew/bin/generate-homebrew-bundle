#!/usr/bin/env fish

set global_brewfile "$HOME/.Brewfile"

echo "# Generated by script "(status filename)" at "(date) > $global_brewfile
# Main
cat $HOME/.dotfiles/Brewfile >> $global_brewfile
# Packages
for brewfile in (find $HOME/.dotfiles/*/ -name Brewfile | sort)
    set package (echo $brewfile | cut -d '/' -f 5)
    echo "# $package" >> $global_brewfile
    cat $brewfile >> $global_brewfile
end
